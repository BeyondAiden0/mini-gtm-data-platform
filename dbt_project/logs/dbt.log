    create  table
      "data"."marts"."fct_opportunities__dbt_tmp"
  
    as (
      -- Denormalized opportunity facts with account, rep, call stats, and marketing context
-- Central fact table for pipeline and deal intelligence analysis
with opportunities as (
    select * from "data"."staging"."stg_opportunities"
),

accounts as (
    select * from "data"."staging"."stg_accounts"
),

-- Aggregate call stats per opportunity
opp_call_stats as (
    select
        opp_id,
        count(*) as total_calls,
        count(case when disposition = 'Completed' then 1 end) as completed_calls,
        sum(case when disposition = 'Completed' then duration_minutes else 0 end) as total_call_minutes,
        avg(case when disposition = 'Completed' then talk_ratio_rep end) as avg_talk_ratio,
        avg(case when disposition = 'Completed' then question_count end) as avg_questions_per_call,
        sum(case when next_steps_mentioned = true then 1 else 0 end) as calls_with_next_steps,
        min(call_date) as first_call_date,
        max(call_date) as last_call_date
    from "data"."staging"."stg_calls"
    group by opp_id
),

-- Count competitor mentions from Gong trackers per opportunity
opp_competitor_mentions as (
    select
        c.opp_id,
        sum(case when ct.tracker_name like 'Competitor%' then ct.mention_count else 0 end) as competitor_mentions,
        sum(case when ct.tracker_name like 'Pricing%' or ct.tracker_name like 'Discount%' then ct.mention_count else 0 end) as pricing_mentions,
        sum(case when ct.tracker_name like 'Risk%' then ct.mention_count else 0 end) as risk_mentions
    from "data"."staging"."stg_calls" c
    inner join "data"."staging"."stg_call_trackers" ct on c.call_id = ct.call_id
    group by c.opp_id
),

-- Lead source attribution (first lead that converted to this opp)
lead_attribution as (
    select
        converted_opp_id as opp_id,
        min(lead_id) as attributed_lead_id,
        min(source) as attributed_lead_source
    from "data"."staging"."stg_leads"
    where converted_opp_id is not null
    group by converted_opp_id
),

-- Slack deal room engagement per opportunity
opp_slack_engagement as (
    select
        ch.opp_id,
        ch.channel_id,
        ch.channel_name,
        ch.num_members as slack_channel_members,
        count(m.message_id) as slack_message_count,
        count(distinct m.sender) as slack_unique_senders,
        avg(m.response_time_minutes) as slack_avg_response_minutes,
        sum(case when m.has_mention then 1 else 0 end) as slack_mentions,
        sum(m.word_count) as slack_total_words,
        min(m.sent_at) as slack_first_message_at,
        max(m.sent_at) as slack_last_message_at
    from "data"."staging"."stg_slack_channels" ch
    left join "data"."staging"."stg_slack_messages" m on ch.channel_id = m.channel_id
    group by ch.opp_id, ch.channel_id, ch.channel_name, ch.num_members
)

select
    o.opp_id,
    o.name as opp_name,
    o.stage,
    o.amount,
    o.close_date,
    o.created_date,
    o.lead_source,
    o.forecast_category,
    o.is_won,
    o.is_closed,
    o.competitor,
    o.loss_reason,
    o.days_in_stage,
    o.next_step,

    -- Account info
    o.account_id,
    a.name as account_name,
    a.industry,
    a.employee_count,
    a.arr as account_arr,
    a.region,
    case
        when a.employee_count <= 200 then 'SMB'
        when a.employee_count <= 2000 then 'Mid-Market'
        else 'Enterprise'
    end as account_segment,

    -- Rep info
    o.owner_id,

    -- Call engagement stats
    coalesce(cs.total_calls, 0) as total_calls,
    coalesce(cs.completed_calls, 0) as completed_calls,
    coalesce(cs.total_call_minutes, 0) as total_call_minutes,
    cs.avg_talk_ratio,
    cs.avg_questions_per_call,
    coalesce(cs.calls_with_next_steps, 0) as calls_with_next_steps,
    cs.first_call_date,
    cs.last_call_date,

    -- Gong intelligence
    coalesce(cm.competitor_mentions, 0) as competitor_mentions,
    coalesce(cm.pricing_mentions, 0) as pricing_mentions,
    coalesce(cm.risk_mentions, 0) as risk_mentions,

    -- Lead attribution
    la.attributed_lead_id,
    la.attributed_lead_source,

    -- Slack deal room engagement
    se.channel_name as slack_channel_name,
    coalesce(se.slack_channel_members, 0) as slack_channel_members,
    coalesce(se.slack_message_count, 0) as slack_message_count,
    coalesce(se.slack_unique_senders, 0) as slack_unique_senders,
    se.slack_avg_response_minutes,
    coalesce(se.slack_mentions, 0) as slack_mentions,
    coalesce(se.slack_total_words, 0) as slack_total_words,
    se.slack_first_message_at,
    se.slack_last_message_at,
    case
        when se.slack_message_count is null or se.slack_message_count = 0 then 'No Channel'
        when se.slack_message_count < 10 then 'Low'
        when se.slack_message_count < 50 then 'Medium'
        else 'High'
    end as slack_engagement_level,

    -- Calculated fields
    case
        when o.is_closed then datediff('day', o.created_date::date, o.close_date::date)
        else datediff('day', o.created_date::date, current_date)
    end as cycle_days,

    o.created_at

from opportunities o
left join accounts a on o.account_id = a.account_id
left join opp_call_stats cs on o.opp_id = cs.opp_id
left join opp_competitor_mentions cm on o.opp_id = cm.opp_id
left join lead_attribution la on o.opp_id = la.opp_id
left join opp_slack_engagement se on o.opp_id = se.opp_id
    );
  
  
