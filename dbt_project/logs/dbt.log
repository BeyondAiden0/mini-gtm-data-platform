[0m16:12:01.590030 [debug] [Thread-1 (]: On model.gtm_data_platform.stg_opportunities: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "gtm_data_platform", "target_name": "dev", "node_id": "model.gtm_data_platform.stg_opportunities"} */

  
  create view "data"."staging"."stg_opportunities__dbt_tmp" as (
    with source as (
    select * from "data"."raw"."opportunities"
),

cleaned as (
    select
        opp_id,
        account_id,
        owner_id,
        name,
        stage,
        -- Fix negative amounts
        case
            when amount < 0 then abs(amount)
            else amount
        end as amount,
        close_date,
        created_date,
        lead_source,
        forecast_category,
        is_won,
        is_closed,
        competitor,
        loss_reason,
        -- Cap days_in_stage at reasonable max
        case
            when days_in_stage < 0 then 0
            when days_in_stage > 365 then 365
            else days_in_stage
        end as days_in_stage,
        next_step,
        created_at
    from source
    where opp_id is not null
        and account_id is not null
        -- Filter out records where close_date is before created_date
        and close_date >= created_date
)

select * from cleaned
  );

